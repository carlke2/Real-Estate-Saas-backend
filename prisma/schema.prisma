// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AGENT
  ADMIN
}

enum PropertyStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum InquiryStatus {
  OPEN
  RESPONDED
  CLOSED
}

enum ListingType {
  SALE
  RENT
}

model User {
  id         String     @id @default(uuid())
  fullName   String
  email      String     @unique
  phone      String
  password   String
  role       Role       @default(USER)
  isVerified        Boolean          @default(false)
  isAgentVerified   Boolean          @default(false)
  bio               String?
  profileImage      String?
  rating            Float?           @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  properties          Property[]
  inquiries           Inquiry[]
  favorites           Favorite[]
  savedSearches       SavedSearch[]
  auditLogs           AuditLog[]
  verificationRequest UserVerification?
}

model Property {
  id           String         @id @default(uuid())
  title        String
  description  String
  price        Float
  location     String
  county       String
  address      String
  bedrooms     Int
  bathrooms    Int
  furnishing   String?
  propertyType String
  listingType  ListingType @default(SALE)
  status       PropertyStatus @default(PENDING)
  isAvailable  Boolean        @default(true)
  isFeatured   Boolean        @default(false)
  viewCount      Int            @default(0)
  area           Float?
  latitude       Float?
  longitude      Float?
  rejectionReason String?
  moderationNotes String?
  createdById    String
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  createdBy  User            @relation(fields: [createdById], references: [id])
  images     PropertyImage[]
  inquiries  Inquiry[]
  favorites  Favorite[]
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  imageUrl   String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id          String        @id @default(uuid())
  propertyId  String
  userId      String?
  name        String
  phone       String
  message     String
  status      InquiryStatus @default(OPEN)
  respondedAt DateTime?
  createdAt   DateTime      @default(now())

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserVerification {
  id           String             @id @default(uuid())
  userId       String             @unique
  idNumber     String
  idImage      String?
  permitNumber String?
  permitImage  String?
  status       VerificationStatus @default(PENDING)
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedSearch {
  id          String   @id @default(uuid())
  userId      String
  name        String
  filters     Json
  lastChecked DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String    @id @default(uuid())
  email     String
  token     String
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@unique([email, token, type])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}
